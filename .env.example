# ─── App ─────────────────────────────────────────────
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ─── WAHA (WhatsApp HTTP API) ─────────────────────────
WAHA_BASE_URL=http://localhost:3000   # URL server WAHA kamu
WAHA_API_KEY=your-waha-api-key
WAHA_SESSION=default                  # nama session WAHA
WAHA_WEBHOOK_SECRET=your-secret       # untuk verifikasi webhook

# ─── AI / LLM ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...              # uncomment kalau pakai OpenAI

LLM_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small   # OpenAI embedding
# EMBEDDING_MODEL=local                  # atau pakai local model

# ─── Database (PostgreSQL) ────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wa_sales_agent
DB_USER=postgres
DB_PASSWORD=your-db-password
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@localhost:5432/wa_sales_agent

# ─── Redis (session & cache) ──────────────────────────
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=86400             # 24 jam

# ─── Vector Store ─────────────────────────────────────
VECTOR_STORE=pgvector                 # pgvector | qdrant
QDRANT_URL=http://localhost:6333      # kalau pakai qdrant
QDRANT_API_KEY=                       # opsional

# ─── Custom ERP ───────────────────────────────────────
ERP_BASE_URL=https://your-erp.com/api
ERP_API_KEY=your-erp-api-key
ERP_TIMEOUT_SECONDS=10
